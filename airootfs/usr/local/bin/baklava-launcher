#!/usr/bin/env bash

# Ensure standard PATH is set
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

clear
printf '\033[1;38;5;205mBaklava Linux Installer\033[0m\n'
printf 'Starting installer...\n\n'

if ! /usr/local/bin/baklava-installer "$@"; then
    printf '\n\033[1;31mInstaller exited with an error.\033[0m\n'
    printf 'Dropping to emergency debug shell...\n\n'
    exec bash
fi
